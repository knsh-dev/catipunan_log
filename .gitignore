# ── Dependencies ─────────────────────────────────────────────
node_modules/
client/node_modules/
server/node_modules/

# ── Environment variables (never commit secrets) ──────────────
.env
.env.*
!.env.example

# ── Build output ──────────────────────────────────────────────
client/dist/
client/.vite/

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Uploads (user-generated files, not source) ────────────────
server/public/uploads/*
!server/public/uploads/.gitkeep
